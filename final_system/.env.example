# ─────────────────────────────────────────────────────────────────────────────
# final_system/.env.example
#
# Шаблон конфигурации окружения. Скопируйте в .env и заполните значения.
#   cp .env.example .env
#
# .env НЕ коммитится в репозиторий. .env.example — коммитится.
# ─────────────────────────────────────────────────────────────────────────────

# ── Системная БД (ProcessRegistry) ───────────────────────────────────────────
# Используется для хранения истории запусков (таблицы processes, process_logs).
# Инициализируется автоматически при docker compose up через db/init_db.sql.
DB_DISABLED=false
DB_HOST=postgres          # имя сервиса в docker-compose; localhost для локального запуска
DB_PORT=5432
DB_NAME=synthetic_data_db
DB_USER=postgres
DB_PASSWORD=              # задайте пароль
DB_SCHEMA=synthetic_data_schema

# ── Redis (RunStore) ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0   # redis://localhost:6379/0 для локального запуска

# ── Импорт данных из БД пользователя ─────────────────────────────────────────
# Активируется когда в конфиге задано: data_import.type: postgres
# Формат: postgresql://user:password@host:port/dbname
DB_IMPORT_DSN=

# ── Экспорт синтетики в БД пользователя ──────────────────────────────────────
# Активируется когда в конфиге задано: data_export.type: postgres
DB_EXPORT_DSN=

# ── API-авторизация ───────────────────────────────────────────────────────────
# Если не задан — авторизация отключена (режим разработки).
# В production обязательно задайте случайный токен: openssl rand -hex 32
API_KEY=

# ── Адреса микросервисов ──────────────────────────────────────────────────────
# При запуске через docker compose значения подставляются автоматически.
# Для локального запуска без Docker замените на localhost.
DATA_SERVICE_URL=http://data_service:8001
SYNTHESIS_SERVICE_URL=http://synthesis_service:8002
EVALUATION_SERVICE_URL=http://evaluation_service:8003
REPORTING_SERVICE_URL=http://reporting_service:8004
